{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "node",
    "target": "es2023",
    "rootDir": "./",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "5.0",
    "types": []
  },
  "include": ["src", "prisma.config.ts", "api"],
  "exclude": ["node_modules", "dist"]
}
