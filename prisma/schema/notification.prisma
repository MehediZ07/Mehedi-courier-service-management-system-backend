model Notification {
  id         String   @id @default(uuid())
  shipmentId String
  userId     String
  role       Role
  message    String
  readStatus Boolean  @default(false)
  createdAt  DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
}
