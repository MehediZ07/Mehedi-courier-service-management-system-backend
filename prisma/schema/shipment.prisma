model Shipment {
  id              String         @id @default(uuid())
  trackingNumber  String         @unique
  senderId        String
  merchantId      String?
  courierId       String?
  pickupAddress   String
  pickupCity      String
  pickupPhone     String         @default("")
  deliveryAddress String
  deliveryCity    String
  deliveryPhone   String         @default("")
  packageType     String
  weight          Float
  priority        Priority       @default(STANDARD)
  status          ShipmentStatus @default(PENDING)
  paymentStatus   PaymentStatus  @default(PENDING)
  proofOfDelivery String?
  note            String?
  
  // NEW: Hub-based delivery fields
  deliveryType    DeliveryType?  // null = legacy, DIRECT, HUB_BASED
  currentLegId    String?        // Track active leg
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  sender        User            @relation("Sender", fields: [senderId], references: [id])
  merchant      Merchant?       @relation(fields: [merchantId], references: [id])
  courier       Courier?        @relation(fields: [courierId], references: [id])
  payment       Payment?
  pricing       ShipmentPricing?
  notifications Notification[]
  events        ShipmentEvent[]
  legs          ShipmentLeg[]   // NEW: Multi-leg journey
}
