model Visit {
  id        String   @id @default(uuid())
  sessionId String?  // Track unique sessions
  ip        String?
  userAgent String?
  userId    String?
  userEmail String?
  userName  String?
  userRole  String?
  page      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([sessionId])
}

// Aggregated page views by hour
model PageViewStat {
  id        String   @id @default(uuid())
  page      String
  date      DateTime @db.Date
  hour      Int      // 0-23
  userRole  String?  // ADMIN, COURIER, MERCHANT, USER, GUEST
  viewCount Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([page, date, hour, userRole])
  @@index([date])
  @@index([page])
}

// Unique visitors per day
model DailyVisitor {
  id        String   @id @default(uuid())
  sessionId String   @unique
  userId    String?
  userEmail String?
  userName  String?
  userRole  String?
  date      DateTime @db.Date
  pages     String[] // Array of pages visited
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([date])
  @@index([userId])
}
